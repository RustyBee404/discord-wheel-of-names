# ===========================================
# Uplup Wheel Discord Bot Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# DISCORD CONFIGURATION (Required)
# -------------------------------------------
# Get these from https://discord.com/developers/applications

# Your bot token (from Bot > Token)
DISCORD_TOKEN=your_bot_token_here

# Your application ID (from General Information)
DISCORD_CLIENT_ID=your_application_id_here

# -------------------------------------------
# UPLUP API CONFIGURATION (Recommended)
# -------------------------------------------
# Get these from https://uplup.com/brand/api-integrations#api-keys
# API access is FREE - create an account at uplup.com
#
# Without API keys: /spin commands work, /wheel commands disabled
# With API keys: All commands work + saved wheels + usage tracking

# Your API key (starts with uplup_live_ or uplup_test_)
UPLUP_API_KEY=

# Your API secret (shown only once when you create the key!)
UPLUP_API_SECRET=

# API base URL (don't change unless using a custom endpoint)
UPLUP_API_BASE_URL=https://api.uplup.com/api/wheel
